{
    "name": "akudovich/user",
    "description": "Test user management application",
    "type": "project",
    "license": "proprietary",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": ">=8.2"
    },
    "require-dev": {
        "deptrac/deptrac": "^4.6",
        "infection/infection": "^0.32.6",
        "phpunit/phpunit": "^11.5",
        "symplify/easy-coding-standard": ">=13.2.2"
    },
    "config": {
        "bump-after-update": true,
        "sort-packages": true,
        "allow-plugins": {
            "infection/extension-installer": true
        }
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "cs-check": "vendor/bin/ecs check --ansi",
        "cs-fix": "vendor/bin/ecs check --fix --ansi",
        "test": "vendor/bin/phpunit",
        "phpstan": "vendor/bin/phpstan --memory-limit=1G",
        "phpunit": "vendor/bin/phpunit",
        "infection": "vendor/bin/infection --threads=4 --min-msi=100 --min-covered-msi=100",
        "deptrac": "vendor/bin/deptrac analyse --cache-file=var/deptrac/cache --ansi",
        "security-audit": "composer audit --locked",
        "coverage": [
            "vendor/bin/phpunit --coverage-text --coverage-html var/coverage --coverage-clover var/coverage/clover.xml"
        ],
        "qa": [
            "@cs-check",
            "@deptrac",
            "@phpstan",
            "@phpunit"
        ]
    }
}
